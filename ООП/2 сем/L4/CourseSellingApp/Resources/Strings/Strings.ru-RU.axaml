<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- General -->
    <system:String x:Key="Title">Приложение для продажи курсов</system:String>

    <!-- MainWindow -->
    <system:String x:Key="Header.AvailableCourses">Доступные курсы</system:String>
    <system:String x:Key="Button.Add">Добавить</system:String>
    <system:String x:Key="Button.Edit">Изменить</system:String>
    <system:String x:Key="Button.Delete">Удалить</system:String>
    <system:String x:Key="Text.SelectCourse">Выберите курс, чтобы увидеть детали.</system:String>

    <!-- Details -->
    <system:String x:Key="Details.Category">Категория:</system:String>
    <system:String x:Key="Details.Rating">Рейтинг:</system:String>
    <system:String x:Key="Details.Price">Цена:</system:String>
    <system:String x:Key="Details.Author">Автор:</system:String>
    <system:String x:Key="Details.AvailableSlots">Свободных мест:</system:String>
    <system:String x:Key="Image.Placeholder">Изображение курса</system:String>

</ResourceDictionary>
