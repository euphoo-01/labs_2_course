<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CourseSellingApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:CourseSellingApp.Models"
        xmlns:services="using:CourseSellingApp.Services"
        xmlns:utils="using:CourseSellingApp.Utils"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CourseSellingApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app_icon.ico"
        Title="{DynamicResource Title}">

    <Window.Resources>
        <utils:BitmapValueConverter x:Key="BitmapValueConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="300,*" RowDefinitions="Auto,*" Margin="10">
        <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource Header.AvailableCourses}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                <Button Content="Login as Client" Command="{Binding LoginCommand}">
                    <Button.CommandParameter>
                        <services:UserRole>Client</services:UserRole>
                    </Button.CommandParameter>
                </Button>
                <Button Content="Login as Admin" Command="{Binding LoginCommand}">
                    <Button.CommandParameter>
                        <services:UserRole>Administrator</services:UserRole>
                    </Button.CommandParameter>
                </Button>
                <Button Content="EN" Command="{Binding ChangeLanguageCommand}" CommandParameter="en-US"/>
                <Button Content="RU" Command="{Binding ChangeLanguageCommand}" CommandParameter="ru-RU"/>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="1">
            <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,10">
                <TextBox Text="{Binding SearchQuery}" Watermark="{DynamicResource Filter.Search}" />
                <Grid ColumnDefinitions="*,*">
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              PlaceholderText="{DynamicResource Filter.Category}"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,5,0"/>
                    <Grid Grid.Column="1" ColumnDefinitions="*,*">
                        <NumericUpDown Grid.Column="0" Value="{Binding MinPrice}" Watermark="{DynamicResource Filter.MinPrice}" ShowButtonSpinner="False" Minimum="0" Margin="0,0,5,0"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding MaxPrice}" Watermark="{DynamicResource Filter.MaxPrice}" ShowButtonSpinner="False" Minimum="0"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Margin="0,10,0,0" IsVisible="{Binding IsAdmin}">
                <Button Content="{DynamicResource Button.Add}" Command="{Binding AddCourseCommand}" />
                <Button Content="{DynamicResource Button.Edit}" Command="{Binding EditCourseCommand}" />
                <Button Content="{DynamicResource Button.Delete}" Command="{Binding DeleteCourseCommand}" />
            </StackPanel>

            <ListBox ItemsSource="{Binding FilteredCourses}" SelectedItem="{Binding SelectedCourse}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Course">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="5">
                            <Border Grid.RowSpan="3" Width="60" Height="60" Background="Gray" Margin="0,0,10,0">
                                <Panel>
                                    <Image Source="{Binding CoverImagePath, Converter={StaticResource BitmapValueConverter}}" Stretch="UniformToFill"/>
                                    <TextBlock Text="Image" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               IsVisible="{Binding CoverImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                </Panel>
                            </Border>

                            <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Author}" FontStyle="Italic"/>
                            <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding Price, StringFormat={}{0:0.00 BYN}}" Foreground="Green"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Border Grid.Column="1" Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="10,0,0,0">
            <Panel>
                <TextBlock Text="{DynamicResource Text.SelectCourse}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="Gray"
                           IsVisible="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNull}}"/>

                <ContentControl Content="{Binding SelectedCourse}"
                                IsVisible="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="models:Course">
                            <ScrollViewer>
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding FullName}" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>

                                    <Border Width="200" Height="200" Background="DarkGray" HorizontalAlignment="Center" Margin="0,10">
                                        <Panel>
                                            <Image Source="{Binding CoverImagePath, Converter={StaticResource BitmapValueConverter}}" Stretch="UniformToFill"/>
                                            <TextBlock Text="{DynamicResource Image.Placeholder}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       IsVisible="{Binding CoverImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                        </Panel>
                                    </Border>

                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    <Separator/>
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Details.Category}" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Category}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Details.Rating}" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Rating, StringFormat={}{0}/5.0}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Details.Price}" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Price, StringFormat={}{0:0.00 BYN}}" Foreground="Green"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Details.Author}" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Author}"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Details.AvailableSlots}" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Quantity}"/>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Panel>
        </Border>
    </Grid>
</Window>
